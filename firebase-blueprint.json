{
  "entities": {
    "ShippingLabel": {
      "title": "Shipping Label",
      "description": "A record of a generated shipping label",
      "type": "object",
      "properties": {
        "recipientName": { "type": "string", "description": "Name of the recipient" },
        "phone": { "type": "string", "description": "Phone number" },
        "address": { "type": "string", "description": "Full address" },
        "zipCode": { "type": "string", "description": "Postal code" },
        "items": { "type": "array", "description": "List of items in the shipment" },
        "labelSize": { "type": "string", "description": "Size of the label (100x75 or 100x150)" },
        "userId": { "type": "string", "description": "Owner of the label record" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["recipientName", "phone", "address", "zipCode", "userId", "createdAt"]
    }
  },
  "firestore": {
    "shipping_labels/{labelId}": {
      "schema": "ShippingLabel",
      "description": "Collection of shipping labels history"
    }
  }
}
